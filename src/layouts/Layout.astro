---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SCOTS — What to Expect From Your Appointment</title>
    <meta name="description" content="Southern Community Orthopaedic Triage Service patient guide." />
    <meta name="theme-color" content="#00263e" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script is:inline>
      window.accessibilityTools = function() {
        return {
          reading: false,
          textSize: 'normal',
          highContrast: false,
          colorBlind: false,

          toggleReadAloud() {
            if (this.reading) {
              window.speechSynthesis.cancel();
              this.reading = false;
              return;
            }
            var main = document.getElementById('main-content');
            if (!main) return;

            var queue = [];
            var blocks = main.querySelectorAll('h1, h2, h3, p, li');
            for (var i = 0; i < blocks.length; i++) {
              var el = blocks[i];
              if (el.hasAttribute('data-no-read') || el.closest('[data-no-read]')) continue;
              var txt = el.innerText.trim();
              if (!txt) continue;
              var tag = el.tagName.toLowerCase();
              var pause = tag.match(/^h[1-3]$/) ? 700 : tag === 'li' ? 500 : 400;
              queue.push({ text: txt, pause: pause });
            }

            if (!queue.length) return;
            this._queue = queue;
            this._index = 0;
            this.reading = true;
            var self = this;

            function next() {
              if (self._index >= self._queue.length || !self.reading) {
                self.reading = false;
                return;
              }
              var item = self._queue[self._index++];
              var u = new SpeechSynthesisUtterance(item.text);
              u.lang = 'en-NZ';
              u.rate = 0.85;
              u.onend = function() { self.reading ? setTimeout(next, item.pause) : null; };
              u.onerror = function() { self.reading = false; };
              window.speechSynthesis.speak(u);
            }
            next();
          },

          cycleSize() {
            var sizes = ['normal', 'large', 'xlarge'];
            var i = (sizes.indexOf(this.textSize) + 1) % sizes.length;
            this.textSize = sizes[i];
            document.documentElement.classList.remove('text-size-large', 'text-size-xlarge');
            if (this.textSize !== 'normal') document.documentElement.classList.add('text-size-' + this.textSize);
            this.announce('Text size: ' + this.textSize);
          },

          toggleContrast() {
            this.highContrast = !this.highContrast;
            document.documentElement.classList.toggle('high-contrast');
            this.announce(this.highContrast ? 'High contrast on' : 'High contrast off');
          },

          toggleColorBlind() {
            this.colorBlind = !this.colorBlind;
            document.documentElement.classList.toggle('color-blind-mode');
            this.announce(this.colorBlind ? 'Color blind mode on' : 'Color blind mode off');
          },

          announce(msg) {
            var el = document.getElementById('a11y-announce');
            if (el) { el.textContent = ''; setTimeout(function() { el.textContent = msg; }, 50); }
          }
        };
      };
    </script>
  </head>
  <body>
    <slot />
    <noscript><style>.fade-up { opacity: 1 !important; transform: none !important; }</style></noscript>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        var els = document.querySelectorAll('.fade-up');
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          els.forEach(function(el) { el.classList.add('visible'); });
          return;
        }
        var obs = new IntersectionObserver(function(entries) {
          entries.forEach(function(e) {
            if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
          });
        }, { threshold: 0.1 });
        els.forEach(function(el) { obs.observe(el); });
      });
    </script>
  </body>
</html>
