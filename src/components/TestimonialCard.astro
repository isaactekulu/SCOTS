---
import { truncateText } from '../utils/truncateText';

interface Props {
  name: string;
  reviewText: string;
  rating: number;
  avatarUrl?: string;
}

const { name, reviewText, rating } = Astro.props;

const displayText = truncateText(reviewText, 200);
const isTruncated = reviewText.length > 200;
const stars = Array.from({ length: 5 }, (_, i) => i < rating);
---

<article class="bg-white rounded-xl border border-border p-8 transition-all duration-200 hover:-translate-y-1 hover:shadow-md">
  <div class="flex items-center gap-1 mb-4" aria-label={`Rating: ${rating} out of 5 stars`}>
    {stars.map((filled) => (
      <svg
        class={`w-5 h-5 ${filled ? 'text-warning' : 'text-gray-200'}`}
        fill="currentColor"
        viewBox="0 0 20 20"
        aria-hidden="true"
      >
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>
  <blockquote class="text-text-secondary text-sm leading-relaxed mb-6">
    <p>"{displayText}"</p>
    {isTruncated && (
      <span class="text-xs text-text-secondary/60 italic">...more</span>
    )}
  </blockquote>
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
      <span class="text-sm font-semibold text-primary">
        {name.charAt(0)}
      </span>
    </div>
    <span class="text-sm font-medium text-text-primary">{name}</span>
  </div>
</article>
