---
import SectionTitle from './SectionTitle.astro';
import CategoryCard from './CategoryCard.astro';

const categories = [
  {
    icon: '<svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>',
    title: 'Assessment',
    description: 'Expert evaluation of your musculoskeletal condition to determine the most appropriate care pathway.',
    iconLabel: 'Assessment clipboard icon',
  },
  {
    icon: '<svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>',
    title: 'Rehabilitation',
    description: 'Targeted, progressive exercise programs to improve strength, mobility, and function.',
    iconLabel: 'Rehabilitation heart icon',
  },
  {
    icon: '<svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>',
    title: 'Education',
    description: 'Evidence-based programs covering nutrition, wellness, and self-management strategies.',
    iconLabel: 'Education book icon',
  },
  {
    icon: '<svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>',
    title: 'Consultation',
    description: 'Specialist referral support for patients who meet the threshold for surgical consideration.',
    iconLabel: 'Consultation people icon',
  },
];
---

<section id="categories" class="py-24">
  <div class="container-custom">
    <SectionTitle
      title="Service Categories"
      subtitle="We provide a range of services to support your musculoskeletal health journey."
    />
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {categories.map((category) => (
        <CategoryCard {...category} />
      ))}
    </div>
  </div>
</section>
