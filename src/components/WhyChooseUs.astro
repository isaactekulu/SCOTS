---
import SectionTitle from './SectionTitle.astro';

const benefits = [
  {
    icon: '<svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>',
    title: 'Premium Quality Care',
    description: 'Expert physiotherapists specialising in musculoskeletal assessment and evidence-based treatment.',
    iconLabel: 'Shield icon representing quality care',
  },
  {
    icon: '<svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>',
    title: 'Sustainable Approach',
    description: 'Long-term strategies focused on self-management and lasting improvements to your health.',
    iconLabel: 'Globe icon representing sustainable approach',
  },
  {
    icon: '<svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>',
    title: 'Fast Service Access',
    description: 'Reduced unnecessary delays and improved access to specialist services when needed.',
    iconLabel: 'Lightning bolt icon representing fast access',
  },
  {
    icon: '<svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>',
    title: 'Trusted Professionals',
    description: 'A dedicated team working closely with GPs, community providers, and orthopaedic specialists.',
    iconLabel: 'People icon representing trusted professionals',
  },
  {
    icon: '<svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" /></svg>',
    title: 'Expert Assessment',
    description: 'Thorough evaluation to determine whether surgery, rehabilitation, or other pathways suit you best.',
    iconLabel: 'Clipboard icon representing expert assessment',
  },
  {
    icon: '<svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>',
    title: 'Evidence-Based Programs',
    description: 'Treatment guided by clinical practice guidelines and proven non-surgical management strategies.',
    iconLabel: 'Chart icon representing evidence-based programs',
  },
];
---

<section class="py-24 bg-surface">
  <div class="container-custom">
    <SectionTitle
      title="Why Choose SCOTS"
      subtitle="We ensure you receive the right treatment, at the right time, for the best possible outcome."
    />
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {benefits.map((benefit) => (
        <div class="bg-white rounded-xl border border-border p-8 transition-all duration-200 hover:-translate-y-1 hover:shadow-md">
          <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mb-5" aria-label={benefit.iconLabel}>
            <Fragment set:html={benefit.icon} />
          </div>
          <h3 class="text-lg font-semibold text-text-primary mb-2">{benefit.title}</h3>
          <p class="text-sm text-text-secondary leading-relaxed">{benefit.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
