---
interface Props {
  title: string;
  subtitle?: string;
  alignment?: 'left' | 'center';
  headingLevel?: 2 | 3 | 4;
}

const { title, subtitle, alignment = 'center', headingLevel = 2 } = Astro.props;

const Tag = `h${headingLevel}` as any;
const alignClass = alignment === 'center' ? 'text-center' : 'text-left';
---

<div class={`mb-12 ${alignClass}`}>
  <Tag class="text-3xl md:text-4xl font-bold text-text-primary mb-4">
    {title}
  </Tag>
  {subtitle && (
    <p class="text-lg text-text-secondary max-w-2xl mx-auto">
      {subtitle}
    </p>
  )}
</div>
