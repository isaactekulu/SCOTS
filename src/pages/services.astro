---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="min-h-screen bg-[#f5f0e8]" x-data="servicesApp()">
    <!-- Header -->
    <div class="px-5 pt-12 pb-6">
      <h1 class="text-[--navy] text-3xl font-bold tracking-tight">Services</h1>
    </div>

    <!-- Category Grid -->
    <div class="px-5 mb-8">
      <div class="grid grid-cols-4 gap-3">
        <template x-for="cat in categories" :key="cat.id">
          <button
            @click="activeCategory = cat.id"
            :class="activeCategory === cat.id ? 'bg-[--teal]/10 border-[--teal] shadow-sm' : 'bg-white/60 border-transparent'"
            class="flex flex-col items-center gap-2 py-4 px-2 rounded-2xl border-2 transition-all duration-200"
          >
            <div
              :class="activeCategory === cat.id ? 'bg-[--teal]/20 text-[--teal]' : 'bg-[#e8e4dc] text-[--text-muted]'"
              class="w-11 h-11 rounded-full flex items-center justify-center transition-colors duration-200"
            >
              <span x-html="cat.icon" class="w-5 h-5"></span>
            </div>
            <span
              :class="activeCategory === cat.id ? 'text-[--teal] font-semibold' : 'text-[--text-muted]'"
              class="text-[12px] transition-colors duration-200"
              x-text="cat.label"
            ></span>
          </button>
        </template>
      </div>
    </div>

    <!-- Results heading -->
    <div class="px-5 mb-4">
      <h2 class="text-[--navy] text-xl font-bold" x-text="getHeading()"></h2>
    </div>

    <!-- Service list -->
    <div class="px-5 pb-24">
      <div class="space-y-0 divide-y divide-[#ddd8cf]">
        <template x-for="item in filteredServices()" :key="item.id">
          <div class="py-4 flex items-center gap-4 transition-all duration-300">
            <div class="w-10 h-10 rounded-full bg-[#e8e4dc] flex items-center justify-center flex-shrink-0">
              <span x-html="getCategoryIcon(item.category)" class="w-5 h-5 text-[--text-muted]"></span>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-[15px] text-[--text] mb-0 truncate" x-text="item.name"></p>
              <p class="text-[13px] text-[--text-muted] mb-0" x-text="item.detail"></p>
            </div>
            <p class="text-[14px] font-semibold text-[--text] whitespace-nowrap mb-0" x-text="'SBD ' + item.price"></p>
          </div>
        </template>
      </div>

      <!-- Empty state -->
      <div x-show="filteredServices().length === 0" class="text-center py-12">
        <p class="text-[--text-muted]">No services available in this category yet.</p>
      </div>
    </div>

    <!-- Bottom nav -->
    <nav class="fixed bottom-0 left-0 right-0 bg-white/90 backdrop-blur-md border-t border-[#ddd8cf] px-4 py-2.5 flex justify-around items-center z-50">
      <a href="#" class="flex flex-col items-center gap-1 text-[--text-muted] no-underline">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <span class="text-[10px]">Discover</span>
      </a>
      <a href="#" class="flex flex-col items-center gap-1 text-[--teal] no-underline">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <span class="text-[10px] font-semibold">Services</span>
      </a>
      <a href="#" class="flex flex-col items-center gap-1 text-[--text-muted] no-underline">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        <span class="text-[10px]">My Trip</span>
      </a>
      <a href="#" class="flex flex-col items-center gap-1 text-[--text-muted] no-underline">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <span class="text-[10px]">Map</span>
      </a>
      <a href="#" class="flex flex-col items-center gap-1 text-[--text-muted] no-underline">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        <span class="text-[10px]">Profile</span>
      </a>
    </nav>
  </div>

  <script>
    function servicesApp() {
      return {
        activeCategory: 'flights',
        categories: [
          { id: 'flights', label: 'Flights', icon: '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>' },
          { id: 'boats', label: 'Boats', icon: '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 17h18M3.7 13.7L5 12l2-2 5-1 5 1 2 2 1.3 1.7M12 2v4m-4 4h8"/></svg>' },
          { id: 'hire', label: 'Hire', icon: '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>' },
          { id: 'guides', label: 'Guides', icon: '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>' },
          { id: 'stays', label: 'Stays', icon: '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>' },
          { id: 'diving', label: 'Diving', icon: '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5"/></svg>' },
          { id: 'transfers', label: 'Transfers', icon: '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>' },
          { id: 'tours', label: 'Tours', icon: '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"/></svg>' },
        ],
        services: [
          // Flights
          { id: 1, category: 'flights', name: 'Solomon Airlines', detail: '45min · Departs ~10:30am', price: 2800 },
          { id: 2, category: 'flights', name: 'Solomon Airlines', detail: '1hr · Departs ~8:00am', price: 3200 },
          { id: 3, category: 'flights', name: 'Solomon Airlines', detail: '50min · Departs ~11:00am', price: 2600 },
          { id: 4, category: 'flights', name: 'Solomon Airlines', detail: '35min · Multiple daily flights', price: 1800 },
          // Boats
          { id: 5, category: 'boats', name: 'MV Fair Glory', detail: '8hr · Departs ~6am, arrives afternoon', price: 450 },
          { id: 6, category: 'boats', name: 'MV Express', detail: '9hr · Departs ~5am', price: 500 },
          { id: 7, category: 'boats', name: 'Island Hopper', detail: '4hr · Morning departures', price: 350 },
          // Hire
          { id: 8, category: 'hire', name: 'Island Car Rentals', detail: 'Sedan · Per day', price: 400 },
          { id: 9, category: 'hire', name: 'Pacific Motorbike', detail: 'Scooter · Per day', price: 150 },
          { id: 10, category: 'hire', name: 'Reef Kayak Hire', detail: 'Single kayak · Half day', price: 100 },
          // Guides
          { id: 11, category: 'guides', name: 'Cultural Village Tour', detail: 'Half day · English speaking', price: 600 },
          { id: 12, category: 'guides', name: 'WWII History Walk', detail: '3hr · Expert historian', price: 450 },
          { id: 13, category: 'guides', name: 'Bird Watching Guide', detail: 'Full day · All equipment', price: 900 },
          // Stays
          { id: 14, category: 'stays', name: 'Heritage Park Hotel', detail: 'Standard room · Per night', price: 1200 },
          { id: 15, category: 'stays', name: 'Coral Sea Resort', detail: 'Ocean view · Per night', price: 1800 },
          { id: 16, category: 'stays', name: 'Village Homestay', detail: 'Authentic experience · Per night', price: 350 },
          // Diving
          { id: 17, category: 'diving', name: 'Bonegi Wreck Dive', detail: '2 dives · Equipment included', price: 800 },
          { id: 18, category: 'diving', name: 'Reef Snorkelling', detail: 'Half day · Guide & gear', price: 300 },
          { id: 19, category: 'diving', name: 'PADI Open Water', detail: '4 day course · Certification', price: 3500 },
          // Transfers
          { id: 20, category: 'transfers', name: 'Airport Shuttle', detail: 'Henderson Airport · One way', price: 150 },
          { id: 21, category: 'transfers', name: 'Hotel Transfer', detail: 'Door to door · Air-con van', price: 200 },
          // Tours
          { id: 22, category: 'tours', name: 'Guadalcanal Day Tour', detail: 'Full day · Lunch included', price: 950 },
          { id: 23, category: 'tours', name: 'Savo Island Volcano', detail: 'Full day · Boat & guide', price: 1400 },
          { id: 24, category: 'tours', name: 'Marovo Lagoon Trip', detail: '2 days · Accommodation included', price: 3200 },
          { id: 25, category: 'tours', name: 'Sunset Fishing Tour', detail: '4hr · Equipment & boat', price: 650 },
        ],
        filteredServices() {
          return this.services.filter(s => s.category === this.activeCategory);
        },
        getHeading() {
          const cat = this.categories.find(c => c.id === this.activeCategory);
          if (this.activeCategory === 'flights') return 'Popular Routes';
          if (this.activeCategory === 'boats') return 'Boat Services';
          return cat ? cat.label : 'Services';
        },
        getCategoryIcon(catId) {
          const cat = this.categories.find(c => c.id === catId);
          return cat ? cat.icon : '';
        }
      };
    }
  </script>
</Layout>
